# RetainIQ Environment Configuration
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#
# COPIE CE FICHIER VERS ".env" ET REMPLACE LES VALEURS PAR LES TIENNES
# cp .env.example .env
#
# ⚠️  NE COMMIT JAMAIS LE FICHIER ".env" (secrètes à l'intérieur)
#
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# ───────────────────────────────────────────────────────────────────
# SendGrid Configuration (Rapports Email Hebdomadaires)
# ───────────────────────────────────────────────────────────────────

# Clé API SendGrid
# - Obtiens-la ici : https://app.sendgrid.com/settings/api_keys
# - Format : commence par "SG."
# - Exemple : SG.6L8kW9pQxYz2A4mN6B3t5R1k9W8...
# - IMPORTANT : Garde-la secrète ! Ne la commit jamais
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Email d'envoi (doit être vérifié dans SendGrid)
# - Obtiens-le ici : https://app.sendgrid.com/settings/sender_auth
# - Exemple : noreply@votreentreprise.com
# - Conseil : crée un email dédié aux rapports
SENDER_EMAIL=noreply@example.com

# Nom affiché dans les emails
SENDER_NAME=RetainIQ

# ───────────────────────────────────────────────────────────────────
# Notes
# ───────────────────────────────────────────────────────────────────
#
# Si SendGrid n'est PAS configuré :
#   → Les rapports PDF sont sauvegardés localement dans reports_archive/
#   → Pas d'erreur, juste un fallback automatique
#
# Configuration pas à pas : voir SENDGRID_SETUP.md
#
